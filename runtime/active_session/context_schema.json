# 当前上下文状态
# TODO: Implement logic here
# runtime/active_session/context_schema.json

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session Context Schema",
  "description": "定义当前会话上下文的标准结构，AI 需遵循此格式更新 context.json",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "description": "唯一会话标识符",
      "example": "a1b2c3d4"
    },
    "start_time": {
      "type": "string",
      "format": "date-time",
      "description": "会话开始时间"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "最后活动时间"
    },
    "user_intent": {
      "type": "string",
      "description": "当前识别的用户意图",
      "example": "create_module"
    },
    "active_modules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "当前会话中激活的模块列表"
    },
    "temporary_variables": {
      "type": "object",
      "description": "会话期间的临时变量存储",
      "additionalProperties": true
    },
    "reflection_pending": {
      "type": "boolean",
      "description": "是否等待反思代理处理",
      "default": false
    }
  },
  "required": ["session_id", "start_time", "last_activity"]
}
